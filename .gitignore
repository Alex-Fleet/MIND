# ───────────────────────────────────────────────
# 🔒 私密运行时数据 —— 绝不进版本控制 / 分享包
# 这是你全部项目的对话史与记忆，别人拿到的应是"系统"而非"你的记忆"
# ───────────────────────────────────────────────
data/
*.db
*.db-journal
*.db-wal

# ── 密钥 / 本地覆盖配置 ──
config.local.json
.env
*.key

# ── 用户私有的项目注册表（slug 分身映射 + 标签），出厂应为空 ──
projects.json

# ── Python ──
__pycache__/
*.py[cod]

# ── 诊断 / 日志 ──
hook_heartbeat.log
*.log

# ── 备份 / OS ──
*.bak
.DS_Store
